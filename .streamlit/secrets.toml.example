# Copy this to .streamlit/secrets.toml for local development with st.secrets.
# (For local dev, environment variables work fine too — secrets.toml is optional.)
#
# On Streamlit Cloud, paste these key/value pairs into the app's
# Settings -> Secrets panel instead of using a file.

GEMINI_API_KEY = "AIza_paste_your_key_here"

# Or, if using the Groq backend instead:
# GROQ_API_KEY = "gsk_paste_your_key_here"
